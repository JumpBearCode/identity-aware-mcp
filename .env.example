# --- Common ---
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# --- MCP server (Entra App registration created by provisioning) ---
MCP_APP_ID=00000000-0000-0000-0000-000000000000
MCP_CLIENT_SECRET=replace-me

# --- AD group IDs that gate tool access ---
DIAGNOSE_GROUP_ID=00000000-0000-0000-0000-000000000000
ACTION_GROUP_ID=00000000-0000-0000-0000-000000000000

# --- diagnose-worker Service Principal (read-only) ---
DIAGNOSE_SP_CLIENT_ID=00000000-0000-0000-0000-000000000000
DIAGNOSE_SP_CLIENT_SECRET=replace-me

# --- action-worker Service Principal (write) ---
ACTION_SP_CLIENT_ID=00000000-0000-0000-0000-000000000000
ACTION_SP_CLIENT_SECRET=replace-me

# --- Local server URL (used in OAuth Protected Resource Metadata) ---
MCP_SERVER_BASE_URL=http://localhost:8080

# --- /mcpproxy (Plan A): extra endpoint that strips the RFC 8707 `resource`
#     param so Claude Code / opencode dodge AADSTS9010010. /mcp is unchanged.
#     Default on; set false to expose only /mcp. See src/mcp-server/mcpproxy.py.
MCPPROXY_ENABLED=true

# --- Execution backend: local docker workers, or ACA sandboxes ---
EXECUTOR=local

# --- Redis (Session sliding window + caches; both paths) ---
REDIS_URL=redis://redis:6379

# --- Execution tuning (all optional; defaults shown) ---
# MCP-side timeout (s): httpx waits this long; workers kill the subprocess 10s earlier.
MCP_EXEC_TIMEOUT=120
# Per-worker cap on stdout/stderr bytes returned to the agent (token control).
MAX_OUTPUT_BYTES=65536
# Session sliding-window TTL (s) — also the Session lifetime.
MCP_SESSION_TTL=1800

# =====================================================================
#  ACA path (EXECUTOR=aca): nothing here is read from this file.
#  The cloud stack deploys via `azd up` — every setting is injected into the
#  Container App by Bicep and captured into the azd env (.azure/<env>/.env),
#  which is the single source of truth. You do NOT hand-populate anything for
#  the cloud path. To make an ACA behavior knob azd-controllable (distributed
#  lock, sandbox idle timers, ...), see the "wire a param to azd" recipe in
#  docs/zh/azd-migration/azd迁移后-部署说明.md  §5.3
#  (English: docs/en/azd-migration/deployment-after-azd.md  §5.3).
# =====================================================================
